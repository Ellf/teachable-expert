---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Fetch all guides
const allGuides = await getCollection('api-guides');

// 2. Sort by newest and grab the top 4 for the homepage grid
const latestGuides = allGuides
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<Layout
	title="Teachable API & Integration Expert"
	description="Custom technical solutions for Teachable creators. API integrations, webhooks, and headless school architecture."
>
	<main class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">

		<header class="mx-auto max-w-3xl text-center mb-16 md:mb-24">
			<div class="mb-6 inline-flex items-center gap-2 rounded-full bg-expert-100 px-3 py-1 text-sm font-mono text-expert-800 dark:bg-expert-900 dark:text-expert-100">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-expert-500 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-expert-500"></span>
        </span>
				Accepting New Projects
			</div>

			<h1 class="mb-6 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl md:text-6xl dark:text-white">
				Beyond the <span class="bg-gradient-to-r from-expert-500 to-blue-600 bg-clip-text text-transparent">Teachable</span> defaults.
			</h1>

			<p class="mb-8 text-lg font-light text-slate-600 md:text-xl dark:text-slate-400">
				I build custom API integrations, real-time webhook architectures, and tailored learning environments for high-volume creators.
			</p>
		</header>

		<section aria-labelledby="expertise-heading">
			<h2 id="expertise-heading" class="sr-only">Technical Expertise</h2>

			<div class="grid grid-cols-1 gap-4 md:grid-cols-3 lg:grid-cols-4 auto-rows-[minmax(200px,auto)]">

				{latestGuides.map((guide, index) => (
					<a
						href={`/api-guides/${guide.id}`}
						class={`group flex flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white transition-all hover:-translate-y-1 hover:border-expert-500 hover:shadow-xl dark:border-slate-800 dark:bg-slate-900/50 ${index === 0 ? 'md:col-span-2 md:row-span-2' : ''}`}
					>
						{guide.data.coverImage && (
							<div class="relative w-full overflow-hidden border-b border-slate-100 aspect-[1200/630] dark:border-slate-800">
								<img
									src={guide.data.coverImage}
									alt={`Cover for ${guide.data.title}`}
									class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
								/>
							</div>
						)}

						<div class="flex flex-grow flex-col justify-between p-6 sm:p-8">
							<div>
								{guide.data.method && (
									<div class="mb-4">
                    <span class="inline-flex items-center rounded-md bg-expert-50 px-2.5 py-1 font-mono text-xs font-semibold text-expert-600 ring-1 ring-inset ring-expert-500/20 dark:bg-expert-500/10 dark:text-expert-400">
                      {guide.data.method}
                    </span>
									</div>
								)}

								<h3 class={`font-bold text-slate-900 dark:text-white ${index === 0 ? 'mb-3 text-2xl' : 'mb-2 text-xl'}`}>
									{guide.data.title}
								</h3>

								<p class={`text-slate-600 dark:text-slate-400 ${index === 0 ? 'text-base' : 'text-sm line-clamp-3'}`}>
									{guide.data.description}
								</p>
							</div>
						</div>
					</a>
				))}

				<div class="flex flex-col items-center justify-center rounded-3xl bg-expert-500 p-8 text-center text-white md:col-span-3 lg:col-span-2">
					<h3 class="mb-4 text-2xl font-bold">Ready to scale your technical infrastructure?</h3>
					<a href="https://purplehippo.io/#contact-form" target="_blank" rel="noopener noreferrer" class="rounded-full bg-white px-6 py-3 font-bold text-expert-900 transition-colors hover:bg-slate-100">
						Let's talk architecture
					</a>
				</div>

			</div>
		</section>
	</main>
</Layout>